{
  "manifest_version": 3,
  "name": "CodeRecall",
  "version": "1.0.0",
  "description": "Track your DSA revisions without leaving the problem page. Log questions, mark revision status, and get email reminders — all from your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://coderecall-api-fthwgyg8duh7e7dk.southeastasia-01.azurewebsites.net/*",
    "https://code-recall-six.vercel.app/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "https://code-recall-six.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://www.leetcode.com/problems/*",
        "https://codeforces.com/problemset/problem/*",
        "https://codeforces.com/contest/*/problem/*",
        "https://www.codechef.com/problems/*",
        "https://www.hackerrank.com/challenges/*",
        "https://www.hackerearth.com/practice/*",
        "https://www.hackerearth.com/problem/*",
        "https://www.geeksforgeeks.org/problems/*",
        "https://practice.geeksforgeeks.org/problems/*",
        "https://atcoder.jp/contests/*/tasks/*",
        "https://www.topcoder.com/challenges/*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    }
  ]
}
